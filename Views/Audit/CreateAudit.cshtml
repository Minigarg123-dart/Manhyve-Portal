
<div class="container-fluid">

    <!-- Header -->
    <div class="mb-3">
        <input type="hidden" value="@ViewBag.ProjectName" />
        <h4 class="mb-0">Create New Audit</h4>
        <p class="text-muted">Fill out the form below to create a new audit entry.</p>
    </div>

    <!-- Card -->
    <div class="card p-4" style="max-width:700px;">

        <div class="row g-3">

            <!-- AGENT -->
            <div class="row">

                <div class="col-md-6">
                    <label class="form-label">AGENT *</label>
                    <select id="agent" class="form-control select-search">
                        <option value="">Select Agent</option>
                        <option value="Ramesh" data-store-id="RM001" data-pincode="120001">Ramesh</option>
                        <option value="Raj" data-store-id="MS002" data-pincode="110002">Raj</option>
                        <option value="Manish" data-store-id="MM003" data-pincode="110003">Manish</option>
                        <option value="Mohit" data-store-id="CS004" data-pincode="110004">Mohit</option>
                        <option value="Amit" data-store-id="GM005" data-pincode="110005">Amit</option>
                    </select>
                </div>

                <div class="col-md-6">
                    <label class="form-label">STORE *</label>
                    <select id="store" class="form-control select-search">
                        <option value="">Select Store</option>
                        <option value="Royal Mall" data-store-id="RM001" data-pincode="110001">Royal Mall</option>
                        <option value="Metro Store" data-store-id="MS002" data-pincode="110002">Metro Store</option>
                        <option value="Mega Mart" data-store-id="MM003" data-pincode="110003">Mega Mart</option>
                        <option value="City Store" data-store-id="CS004" data-pincode="110004">City Store</option>
                    </select>
                </div>

            </div>

            <!-- UPLOAD PHOTO -->
            <div class="col-md-12">
                <label class="form-label">UPLOAD PHOTO *</label>

                <!-- Hidden input -->
                <input type="file" id="photoInput" style="display:none;" />

                <!-- Upload box -->
                <div id="uploadPhotoBox"
                     style="border:2px dashed #ddd; border-radius:10px; padding:20px; text-align:center; cursor:pointer;">

                    <span id="photoText" class="text-muted">
                        Choose File — No file chosen
                    </span>
                </div>
            </div>

            <!-- LATITUDE -->
            <div class="col-md-6">
                <label class="form-label">LATITUDE</label>
                <input type="text" class="form-control" placeholder="Enter latitude" />
            </div>

            <!-- LONGITUDE -->
            <div class="col-md-6">
                <label class="form-label">LONGITUDE</label>
                <input type="text" class="form-control" placeholder="Enter longitude" />
            </div>

        </div>

        <!-- Button -->
        <div class="mt-4">
            <button class="btn btn-primary">
                <i class="fas fa-plus-square me-2"></i> Create Audit
            </button>
        </div>

    </div>
</div>
@section Scripts{
<script>
    $(document).ready(function () {

        $('.select-search').select2({
            width: '100%',
            placeholder: "Search here",
            allowClear: true,
            matcher: function(params, data) {
                // If there is no search term, return all data
                if ($.trim(params.term) === '') {
                    return data;
                }

                if (typeof data.text === 'undefined') return null;

                var term = params.term.toLowerCase();
                var text = (data.text || '').toLowerCase();

                // data.element is the original option element
                var $elem = $(data.element);
                var storeId = ($elem.data('store-id') || '').toString().toLowerCase();
                var pincode = ($elem.data('pincode') || '').toString().toLowerCase();

                if (text.indexOf(term) > -1 || storeId.indexOf(term) > -1 || pincode.indexOf(term) > -1) {
                    return data;
                }

                // No match
                return null;
            },
            templateResult: function(data) {
                // Show name, store id and pincode in dropdown list
                if (!data.id) return data.text; // placeholder or group

                var $elem = $(data.element);
                var storeId = $elem.data('store-id') || '';
                var pincode = $elem.data('pincode') || '';

                var escText = data.text;
                var meta = '';
                if (storeId) meta += 'ID: ' + storeId;
                if (pincode) meta += (meta ? ' • ' : '') + 'PIN: ' + pincode;

                var html = '<div class="select2-custom-result">'
                    + '<div style="font-weight:700;color:#0b1220">' + escText + '</div>';
                if (meta) html += '<div style="font-size:12px;color:#6b7280;margin-top:3px">' + meta + '</div>';
                html += '</div>';

                return $(html);
            },
            templateSelection: function(data) {
                // Show name plus small meta in selection area
                if (!data.id) return data.text;
                var $elem = $(data.element);
                var storeId = $elem.data('store-id') || '';
                var pincode = $elem.data('pincode') || '';
                var meta = '';
                if (storeId) meta += storeId;
                if (pincode) meta += (meta ? ' • ' : '') + pincode;
                return data.text + (meta ? (' — ' + meta) : '');
            },
            escapeMarkup: function(m) { return m; }
        });

    });
</script>}