<!-- ADD ROLE MODAL -->
<div class="modal fade" id="addRoleModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <!-- Header -->
            <div class="modal-header">
                <h5 class="modal-title">Add New Role</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <!-- Body -->
            <div class="modal-body">

                <div class="mb-3">
                    <label class="form-label">Role Name</label>
                    <input type="text" id="roleName" class="form-control" placeholder="Enter role name..." />
                </div>

                <!-- Permissions -->
                <div class="card p-3">

                    <div class="row">
                        <div class="col-6">
                            <input type="checkbox" id="permView" class="me-2" /> View
                        </div>
                        <div class="col-6">
                            <input type="checkbox" id="permCreate" class="me-2" /> Create
                        </div>
                    </div>

                    <div class="row mt-2">
                        <div class="col-6">
                            <input type="checkbox" id="permEdit" class="me-2" /> Edit
                        </div>
                        <div class="col-6">
                            <input type="checkbox" id="permDelete" class="me-2" /> Delete
                        </div>
                    </div>

                </div>

            </div>

            <!-- Footer -->
            <div class="modal-footer">
                <button class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary" onclick="saveRole()">Save Role</button>
            </div>

        </div>
    </div>
</div>
<script>
    function saveRole() {
        const name = document.getElementById("roleName").value;

        if (!name) {
            alert("Please enter role name");
            return;
        }

        const view = document.getElementById("permView").checked ? "checked" : "";
        const create = document.getElementById("permCreate").checked ? "checked" : "";
        const edit = document.getElementById("permEdit").checked ? "checked" : "";
        const del = document.getElementById("permDelete").checked ? "checked" : "";

        const row = `
            <tr>
                <td>${name}</td>
                <td><input type="checkbox" ${view}></td>
                <td><input type="checkbox" ${create}></td>
                <td><input type="checkbox" ${edit}></td>
                <td><input type="checkbox" ${del}></td>
            </tr>`;

        document.querySelector("table tbody").insertAdjacentHTML("beforeend", row);

        // Close modal
        const modal = bootstrap.Modal.getInstance(document.getElementById('addRoleModal'));
        modal.hide();

        // Reset form
        document.getElementById("roleName").value = "";
        document.querySelectorAll('#addRoleModal input[type="checkbox"]').forEach(cb => cb.checked = false);
    }
</script>