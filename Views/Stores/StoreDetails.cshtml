@model dynamic

<div class="container py-4">
    <input type="hidden" value="@ViewBag.ProjectName" />
    <a href="/Stores/StoreAudits?projectName=@ViewBag.ProjectNames" class="text-decoration-none">
        ← BACK TO STORES
    </a>

    <div class="d-flex justify-content-between align-items-center mt-3">

        <div>
            <h2>@Model.Name</h2>

            <p class="text-muted">
                @Model.Address
            </p>

            <p>
                <strong>Store Code:</strong> @Model.Code
            </p>
        </div>

        <button class="btn btn-primary">
            <i class="fas fa-download me-2"></i> Download CSV
        </button>

    </div>

    <hr />

    <!-- STATS -->
    <div class="row g-3 mb-4">

        <div class="col-md-4">
            <div class="card p-3 text-center">
                <small>Total Photos</small>
                <h3>@Model.Total</h3>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card p-3 text-center">
                <small>Pending</small>
                <h3>@Model.Pending</h3>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card p-3 text-center">
                <small>Approved</small>
                <h3>@Model.Approved</h3>
            </div>
        </div>

    </div>

    <!-- PHOTOS SECTION -->
    <div class="card p-4">

        <div class="d-flex justify-content-between mb-3">

            <h4>Photos</h4>

            <select class="form-select w-auto">
                <option>All Photos</option>
                <option>Pending</option>
                <option>Approved</option>
            </select>

        </div>

        <div class="text-center text-muted py-5">
            This store has no photos yet.
        </div>

    </div>

</div>