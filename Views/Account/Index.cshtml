@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
<title>Login</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<style>
body {
     height: 100vh;
     margin: 0;
     font-family: 'Segoe UI';
     background: #f5f6fb;
}

.login-container {
     display: flex;
     height: 100vh;
}

/* LEFT SIDE */
.left-section {
     width: 50%;
     background: linear-gradient(120deg,#eef1ff,#dfe4ff);
     display: flex;
     align-items: center;
     justify-content: center;
     text-align: center;
}
.left-content h1 {
     font-size: 40px;
     font-weight: 700;
     margin-top: 20px;
}
.left-content p {
     color: #6c757d;
     margin-top: 10px;
     font-size: 18px;
}
/* RIGHT SIDE */
.right-section {
     width: 50%;
     display: flex;
     align-items: center;
     justify-content: center;
}
.login-card {
     width: 420px;
     background: white;
     padding: 40px;
     border-radius: 15px;
     box-shadow: 0 10px 25px rgba(0,0,0,0.08);
}
.login-card h2 {
     text-align: center;
     color: #6a6fdc;
     font-weight: 700;
     margin-bottom: 10px;
}
.login-card p {
     text-align: center;
     color: #777;
     margin-bottom: 25px;
}
.form-control {
     height: 48px;
     border-radius: 10px;
}

.btn-login {
     width: 100%;
     height: 50px;
     border-radius: 12px;
     border: none;
     color: white;
     font-weight: 600;
     background: linear-gradient(90deg,#5f72ff,#9b4dca);
}
.btn-login:hover {
     opacity: .9;
}
</style>
</head>
<body>
    <div class="login-container">

        <!-- LEFT SIDE -->

        <div class="left-section">

            <div class="left-content">

                <img src="/images/logo.png" width="180">

                <h1>Welcome Back!</h1>

                <p>
                    Sign in to access your admin dashboard and manage
                    your platform with ease.
                </p>

            </div>

        </div>

        <!-- RIGHT SIDE -->

        <div class="right-section">

            <div class="login-card">

                <h2>Login</h2>

                <p>Please enter your credentials to continue</p>

                <form method="post" asp-controller="Account" asp-action="Login">
                    <div class="mb-3">
                        <label>USERNAME</label>
                        <input type="text" class="form-control" placeholder="Enter your username">
                    </div>
                    <div class="mb-3">
                        <label>PASSWORD</label>
                        <input type="password" class="form-control" placeholder="Enter your password">
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <div>
                            <input type="checkbox"> Remember me
                        </div>
                        <a href="#">Forgot password?</a>
                    </div>
                  @*   <button class="btn-login">Sign In</button> *@
                    <a href="/Home/Index" class="btn-login d-flex align-items-center justify-content-center">
                        Sign In
                    </a>
                </form>
            </div>
        </div>
    </div>
</body>
</html>