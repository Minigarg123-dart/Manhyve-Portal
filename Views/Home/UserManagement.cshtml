    document.addEventListener("click", function(e) {

        if (e.target.classList.contains("changePermission")) {

            e.preventDefault();

            // Get user row
            var row = e.target.closest("tr");

            // Get user role
            var roleInput = row.querySelector(".userRole");

            if (!roleInput) {
                alert("User role not defined");
                return;
            }

            var role = roleInput.value;

            // Find role in roles table
            var roleRow = document.querySelector('#rolesTable tr[data-role="' + role + '"]');

            if (!roleRow) {
                alert("Role not found");
                return;
            }

            // Set role name
            document.getElementById("roleName").value = role;

            // Reset all checkboxes first
            document.querySelectorAll('#addRoleModal input[type="checkbox"]').forEach(cb => {
                cb.checked = false;
            });

            // Load role permissions
            var viewChecked = roleRow.querySelector(".role-perm-view").checked;
            var createChecked = roleRow.querySelector(".role-perm-create").checked;
            var editChecked = roleRow.querySelector(".role-perm-edit").checked;
            var deleteChecked = roleRow.querySelector(".role-perm-delete").checked;

            document.getElementById("permView").checked = viewChecked;
            document.getElementById("permCreate").checked = createChecked;
            document.getElementById("permEdit").checked = editChecked;
            document.getElementById("permDelete").checked = deleteChecked;

            // Show containers based on permission
            document.getElementById("pageAccessViewContainer").style.display = viewChecked ? "block" : "none";
            document.getElementById("pageAccessCreateContainer").style.display = createChecked ? "block" : "none";
            document.getElementById("pageAccessEditContainer").style.display = editChecked ? "block" : "none";
            document.getElementById("pageAccessDeleteContainer").style.display = deleteChecked ? "block" : "none";


            // Load pages for VIEW
            var viewPages = roleRow.getAttribute("data-view-pages");

            if (viewPages === "ALL") {

                document.querySelectorAll('#addRoleModal input[name="pageAccessView"]').forEach(cb => {
                    cb.checked = true;
                });

            } else if (viewPages) {

                viewPages.split("|").forEach(function(page) {
                    var cb = document.querySelector('#addRoleModal input[name="pageAccessView"][value="' + page + '"]');
                    if (cb) cb.checked = true;
                });

            }


            // Load pages for CREATE
            var createPages = roleRow.getAttribute("data-create-pages");

            if (createPages === "ALL") {

                document.querySelectorAll('#addRoleModal input[name="pageAccessCreate"]').forEach(cb => {
                    cb.checked = true;
                });

            } else if (createPages) {

                createPages.split("|").forEach(function(page) {
                    var cb = document.querySelector('#addRoleModal input[name="pageAccessCreate"][value="' + page + '"]');
                    if (cb) cb.checked = true;
                });

            }


            // Load pages for EDIT
            var editPages = roleRow.getAttribute("data-edit-pages");

            if (editPages === "ALL") {

                document.querySelectorAll('#addRoleModal input[name="pageAccessEdit"]').forEach(cb => {
                    cb.checked = true;
                });

            } else if (editPages) {

                editPages.split("|").forEach(function(page) {
                    var cb = document.querySelector('#addRoleModal input[name="pageAccessEdit"][value="' + page + '"]');
                    if (cb) cb.checked = true;
                });

            }


            // Load pages for DELETE
            var deletePages = roleRow.getAttribute("data-delete-pages");

            if (deletePages === "ALL") {

                document.querySelectorAll('#addRoleModal input[name="pageAccessDelete"]').forEach(cb => {
                    cb.checked = true;
                });

            } else if (deletePages) {

                deletePages.split("|").forEach(function(page) {
                    var cb = document.querySelector('#addRoleModal input[name="pageAccessDelete"][value="' + page + '"]');
                    if (cb) cb.checked = true;
                });

            }

            // Open modal
            var modal = new bootstrap.Modal(document.getElementById("addRoleModal"));
            modal.show();
        }

    });
</script>