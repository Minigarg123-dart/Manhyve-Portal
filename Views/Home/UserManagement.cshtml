<!-- ADD ROLE MODAL -->
<div class="modal fade" id="addRoleModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <!-- Header -->
            <div class="modal-header">
                <h5 class="modal-title">Add New Role</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <!-- Body -->
<div class="modal-body">

                <div class="mb-3">
                    <label class="form-label">Role Name</label>
                    <input type="text" id="roleName" class="form-control" placeholder="Enter role name..." />
                </div>

                <!-- Permissions -->
                <div class="card p-3">

                    <div class="row">
                        <div class="col-6">
                            <input type="checkbox" id="permView" class="me-2" /> View
                        </div>
                        <div class="col-6">
                            <input type="checkbox" id="permCreate" class="me-2" /> Create
                        </div>
                    </div>

                    <div class="row mt-2">
                        <div class="col-6">
                            <input type="checkbox" id="permEdit" class="me-2" /> Edit
                        </div>
                        <div class="col-6">
                            <input type="checkbox" id="permDelete" class="me-2" /> Delete
                        </div>
                    </div>

                </div>

                <!-- Page Access containers for each permission -->
                @using System.IO
                @{ 
                    var viewsRoot = System.IO.Path.Combine(System.IO.Directory.GetCurrentDirectory(), "Views");
                    var files = new List<string>();
                    if (System.IO.Directory.Exists(viewsRoot)) {
                        files = System.IO.Directory.GetFiles(viewsRoot, "*.cshtml", System.IO.SearchOption.AllDirectories)
                                .Where(f => !System.IO.Path.GetFileName(f).StartsWith("_") )
                                .Select(f => f.Substring(viewsRoot.Length + 1).Replace("\\", "/")).OrderBy(s=>s).ToList();
                    }

                    // Exclude internal pages and map some paths to user-friendly labels
                    var exclude = new HashSet<string>(new[] { "Account/Index.cshtml", "Home/Privacy.cshtml", "Shared/Error.cshtml" }, System.StringComparer.OrdinalIgnoreCase);
                    var labelMap = new Dictionary<string,string>(System.StringComparer.OrdinalIgnoreCase) {
                        { "Home/Index.cshtml", "Main Dashboard" },
                        { "Home/UserManagement.cshtml", "Main Usermangement" },
                        { "UserManagement/Index.cshtml", "ProjectsUsermanagement" }
                    };

                    var displayFiles = new List<System.Tuple<string,string>>();
                    foreach(var p in files) {
                        if (exclude.Contains(p)) continue;
                        var label = labelMap.ContainsKey(p) ? labelMap[p] : System.IO.Path.GetFileNameWithoutExtension(p);
                        displayFiles.Add(System.Tuple.Create(p, label));
                    }
                }

                <div id="pageAccessViewContainer" class="card p-3 mt-3" style="display:none;">
                    <p class="mb-2 fw-semibold">View - Select pages this role may view</p>
                    <div class="row">
                        @foreach(var t in displayFiles) {
                            <div class="col-md-6 mb-2">
                                <label class="d-block"><input type="checkbox" name="pageAccessView" value="@t.Item1" class="me-2" /> @t.Item2</label>
                            </div>
                        }
                        @if(!displayFiles.Any()) {
                            <div class="col-12 text-muted">No view pages found to list.</div>
                        }
                    </div>
                </div>

                <div id="pageAccessCreateContainer" class="card p-3 mt-3" style="display:none;">
                    <p class="mb-2 fw-semibold">Create - Select pages this role may create on</p>
                    <div class="row">
                        @foreach(var t in displayFiles) {
                            <div class="col-md-6 mb-2">
                                <label class="d-block"><input type="checkbox" name="pageAccessCreate" value="@t.Item1" class="me-2" /> @t.Item2</label>
                            </div>
                        }
                        @if(!displayFiles.Any()) {
                            <div class="col-12 text-muted">No pages found to list.</div>
                        }
                    </div>
                </div>

                <div id="pageAccessEditContainer" class="card p-3 mt-3" style="display:none;">
                    <p class="mb-2 fw-semibold">Edit - Select pages this role may edit</p>
                    <div class="row">
                        @foreach(var t in displayFiles) {
                            <div class="col-md-6 mb-2">
                                <label class="d-block"><input type="checkbox" name="pageAccessEdit" value="@t.Item1" class="me-2" /> @t.Item2</label>
                            </div>
                        }
                        @if(!displayFiles.Any()) {
                            <div class="col-12 text-muted">No pages found to list.</div>
                        }
                    </div>
                </div>

                <div id="pageAccessDeleteContainer" class="card p-3 mt-3" style="display:none;">
                    <p class="mb-2 fw-semibold">Delete - Select pages this role may delete on</p>
                    <div class="row">
                        @foreach(var t in displayFiles) {
                            <div class="col-md-6 mb-2">
                                <label class="d-block"><input type="checkbox" name="pageAccessDelete" value="@t.Item1" class="me-2" /> @t.Item2</label>
                            </div>
                        }
                        @if(!displayFiles.Any()) {
                            <div class="col-12 text-muted">No pages found to list.</div>
                        }
                    </div>
                </div>

            </div>

            <!-- Footer -->
            <div class="modal-footer">
                <button class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary" onclick="saveRole()">Save Role</button>
            </div>

        </div>
    </div>
</div>
<script>
    function saveRole() {
        const name = document.getElementById("roleName").value;

        if (!name) {
            alert("Please enter role name");
            return;
        }

        const view = document.getElementById("permView").checked ? "checked" : "";
        const create = document.getElementById("permCreate").checked ? "checked" : "";
        const edit = document.getElementById("permEdit").checked ? "checked" : "";
        const del = document.getElementById("permDelete").checked ? "checked" : "";

        const row = `
                <tr>
                    <td>${name}</td>
                    <td><input type="checkbox" ${view}></td>
                    <td><input type="checkbox" ${create}></td>
                    <td><input type="checkbox" ${edit}></td>
                    <td><input type="checkbox" ${del}></td>
                </tr>`;

        // Collect selected pages for this role (only if View permission is enabled)
        let pagesData = '';
        if (document.getElementById("permView").checked) {
            const selectedPages = Array.from(document.querySelectorAll('#addRoleModal input[name="pageAccess"]:checked')).map(cb => cb.value);
            pagesData = selectedPages.join('|');
        }

        // Insert row with data-pages attribute so we can reference which pages were allowed
        const rowWithData = `<tr data-pages="${pagesData}">
                    <td>${name}</td>
                    <td><input type="checkbox" ${view}></td>
                    <td><input type="checkbox" ${create}></td>
                    <td><input type="checkbox" ${edit}></td>
                    <td><input type="checkbox" ${del}></td>
                </tr>`;

        document.querySelector("table tbody").insertAdjacentHTML("beforeend", rowWithData);

        // Close modal
        const modal = bootstrap.Modal.getInstance(document.getElementById('addRoleModal'));
        modal.hide();

        // Reset form
        document.getElementById("roleName").value = "";
        document.querySelectorAll('#addRoleModal input[type="checkbox"]').forEach(cb => cb.checked = false);
        // hide page access containers after reset
        ['pageAccessViewContainer','pageAccessCreateContainer','pageAccessEditContainer','pageAccessDeleteContainer'].forEach(id => {
            var el = document.getElementById(id);
            if (el) el.style.display = 'none';
        });
    }

    // Toggle page access visibility when View checkbox changes
    document.addEventListener('DOMContentLoaded', function(){
        var permView = document.getElementById('permView');
        var pageAccessContainer = document.getElementById('pageAccessContainer');
        if (permView) {
            permView.addEventListener('change', function(){
                var el = document.getElementById('pageAccessViewContainer');
                if (this.checked) el.style.display = 'block'; else { el.style.display='none'; el.querySelectorAll('input[name="pageAccessView"]').forEach(cb=>cb.checked=false); }
            });
        }
        var permCreate = document.getElementById('permCreate');
        if (permCreate) {
            permCreate.addEventListener('change', function(){
                var el = document.getElementById('pageAccessCreateContainer');
                if (this.checked) el.style.display = 'block'; else { el.style.display='none'; el.querySelectorAll('input[name="pageAccessCreate"]').forEach(cb=>cb.checked=false); }
            });
        }
        var permEdit = document.getElementById('permEdit');
        if (permEdit) {
            permEdit.addEventListener('change', function(){
                var el = document.getElementById('pageAccessEditContainer');
                if (this.checked) el.style.display = 'block'; else { el.style.display='none'; el.querySelectorAll('input[name="pageAccessEdit"]').forEach(cb=>cb.checked=false); }
            });
        }
        var permDelete = document.getElementById('permDelete');
        if (permDelete) {
            permDelete.addEventListener('change', function(){
                var el = document.getElementById('pageAccessDeleteContainer');
                if (this.checked) el.style.display = 'block'; else { el.style.display='none'; el.querySelectorAll('input[name="pageAccessDelete"]').forEach(cb=>cb.checked=false); }
            });
        }
    });

