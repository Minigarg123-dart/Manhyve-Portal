@{
    ViewData["Title"] = "Form Page";
}

<div class="container-fluid">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-3">

        <div>
            <h3 class="mb-0">Form Page</h3>
            <p class="mb-0 text-muted">Choose a form to get started</p>
        </div>

        <div class="d-flex gap-2">
            @*<button class="btn btn-outline-secondary btn-sm">
                Main Form Settings
            </button> *@
            <a asp-controller="CreateForm"
                   asp-action="MainFormSettings"
                   asp-route-projectName="@ViewBag.ProjectName"
                   class="btn btn-outline-secondary btn-sm">
                ⚙️ Main Form Settings
            </a>
            <a asp-controller="CreateForm"
                   asp-action="VendorFormSettings"
                   asp-route-projectName="@ViewBag.ProjectName"
                   class="btn btn-outline-secondary btn-sm">
                    👔 Vendor Admin Form Settings
            </a>
        </div>

    </div>

    <!-- Forms Row -->
    <div class="row g-3">

        <!-- Form Card 1 -->
        <div class="col-md-4 d-flex">
            <div class="card p-3 flex-fill">

                <div class="d-flex justify-content-between align-items-center mb-2">

                    <span class="badge bg-light text-dark">
                        CMC
                    </span>

                    <span class="badge bg-light text-dark">
                        Store Audit
                    </span>

                </div>

                <h6 class="fw-semibold">
                    CMC (Kalinga Stone) Audit
                </h6>

                <p class="text-muted small mb-3">
                    Audit description <br />
                    Instructions: Mark "Y" for Yes, "N" for No,
                    "NA" for Not Applicable.
                </p>

                <small class="text-muted mb-3 d-block">
                    Created: 11/15/2025
                </small>

                <div class="d-flex justify-content-between align-items-center">

                    <button class="btn btn-primary btn-sm flex-grow-1 me-2">
                        <i class="fa fa-play me-1"></i> Start Form
                    </button>

                    <button class="btn btn-light btn-sm me-1">
                        <i class="fa fa-upload"></i>
                    </button>

                    <button class="btn btn-light btn-sm me-1">
                        <i class="fa fa-copy"></i>
                    </button>

                    <button class="btn btn-light btn-sm text-danger">
                        <i class="fa fa-trash"></i>
                    </button>

                </div>

            </div>
        </div>

        <!-- Form Card 2 -->
        <div class="col-md-4 d-flex">
            <div class="card p-3 flex-fill">

                <div class="d-flex justify-content-between align-items-center mb-2">

                    <span class="badge bg-light text-dark">
                        CASTROL
                    </span>

                    <span class="badge bg-light text-dark">
                        Store Audit
                    </span>

                </div>

                <h6 class="fw-semibold">
                    Store Audit v2
                </h6>

                <p class="text-muted small mb-3">
                    Ten Photos <br />
                    Castrol Audit form <br />
                    Updated checklist...
                </p>

                <small class="text-muted mb-3 d-block">
                    Created: 11/17/2025
                </small>

                <div class="d-flex justify-content-between align-items-center">

                    <button class="btn btn-primary btn-sm flex-grow-1 me-2">
                        <i class="fa fa-play me-1"></i> Start Form
                    </button>

                    <button class="btn btn-light btn-sm me-1">
                        <i class="fa fa-upload"></i>
                    </button>

                    <button class="btn btn-light btn-sm me-1">
                        <i class="fa fa-copy"></i>
                    </button>

                    <button class="btn btn-light btn-sm text-danger">
                        <i class="fa fa-trash"></i>
                    </button>

                </div>

            </div>
        </div>


        <!-- Form Card 3 -->
        <div class="col-md-4 d-flex">
            <div class="card p-3 flex-fill">
                <div class="d-flex justify-content-between align-items-center mb-2">

                    <span class="badge bg-light text-dark">
                        CASTROL
                    </span>

                    <span class="badge bg-light text-dark">
                        Onboarding
                    </span>

                </div>

                <h6 class="fw-semibold">
                    GIG Worker Onboarding
                </h6>

                <p class="text-muted small mb-3">
                    Agent Onboarding Form <br />
                    Clearly show the customer's printed name.
                </p>

                <small class="text-muted mb-3 d-block">
                    Created: 11/28/2025
                </small>

                <div class="d-flex justify-content-between align-items-center">

                    <button class="btn btn-primary btn-sm flex-grow-1 me-2">
                        <i class="fa fa-play me-1"></i> Start Form
                    </button>

                    <button class="btn btn-light btn-sm me-1">
                        <i class="fa fa-upload"></i>
                    </button>

                    <button class="btn btn-light btn-sm me-1">
                        <i class="fa fa-copy"></i>
                    </button>

                    <button class="btn btn-light btn-sm text-danger">
                        <i class="fa fa-trash"></i>
                    </button>

                </div>

            </div>
        </div>

    </div>

</div>