<div class="container-fluid">

    <!-- Header -->
    <div class="mb-3">
        <h4 class="mb-0">Upload Store Data</h4>
        <p class="text-muted">
            Upload a collection of Excel files with store data
        </p>
    </div>

    <div class="row g-3 align-items-stretch">

        <!-- LEFT SIDE -->
        <div class="col-md-7">
            <div class="card p-4 text-center h-100">

                <input type="file" id="dataFile" accept=".csv,.xlsx" style="display:none;" />

                <div id="uploadBox"
                     style="border:2px dashed #ddd; border-radius:10px; padding:40px; cursor:pointer;">

                    <i class="fas fa-file-upload fa-3x mb-3 text-muted"></i>

                    <h6 class="mb-1">Click to browse or drag and drop Excel file</h6>
                    <p class="text-muted small">Click to browse or drag and drop Excel file</p>

                    <p id="fileName" class="mt-2 text-primary small"></p>
                </div>

                <div class="d-flex align-items-center gap-2 mt-4">

                    <button class="btn btn-primary d-flex align-items-center justify-content-center flex-fill">
                        <i class="fas fa-upload me-2"></i>
                        Preview & Map Columns
                    </button>

                    <a asp-controller="CreateForm"
                           asp-action="FormPage"
                           asp-route-projectName="@ViewBag.ProjectName"
                           class="btn btn-outline-secondary d-flex align-items-center justify-content-center flex-fill">
                        Submit
                    </a>
                </div>
            </div>
        </div>

        <!-- RIGHT SIDE -->
        <div class="col-md-5">
            <div class="card p-4 h-100">

                <h6 class="mb-3">
                    <i class="fas fa-info-circle me-2"></i> Instructions
                </h6>

                <ol class="text-muted small ps-3">
                    <li>Click Preview & Map Columns to see available columns</li>
                    <li>Map Excel columns to database fields</li>
                    <li>Optional fields: City, State, Pincode, Store Code</li>
                    <li>Optional field Store Code (auto-generated if not provided)</li>
                    <li>Click Submit</li>
                </ol>

                <div class="mt-3 p-2" style="background:#f5f5f5; border-radius:6px;">
                    <small class="text-muted">
                        Note: Phone numbers must be exactly 10 digits. Store codes are auto-generated from store ID if not provided.
                    </small>
                </div>

            </div>
        </div>

    </div>

</div>